# Frontend API base. Use /api when frontend and backend share the same host.
VITE_API_URL=/api

# Optional public URL used when sharing links from a native app build.
VITE_PUBLIC_APP_URL=

# Optional absolute API base for Capacitor/native builds.
VITE_NATIVE_API_URL=

# Database
DB_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgres://acordesai:replace-with-a-strong-password@postgres:5432/acordesai

# JWT
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Frontend
FRONTEND_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Providers (optional - per-user in database)
OPENAI_API_KEY=
GEMINI_API_KEY=
