# Frontend API base. Use /api when frontend and backend share the same host.
VITE_API_URL=/api

# Optional public URL used when sharing links from a native app build.
VITE_PUBLIC_APP_URL=

# Optional absolute API base for Capacitor/native builds.
VITE_NATIVE_API_URL=

# Database
DB_PASSWORD=changeme
DATABASE_URL=postgres://acordesai:changeme@postgres:5432/acordesai

# JWT
JWT_SECRET=changeme

# AI Providers (optional - per-user in database)
OPENAI_API_KEY=
GEMINI_API_KEY=
